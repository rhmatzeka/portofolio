{
  "discord.enabled": false,
  "vscord.enable": true,
  "vscord.app.name": "Code",
  "vscord.app.privacyMode.enable": false,
  "vscord.status.showElapsedTime": true,
  "vscord.status.resetElapsedTimePerFile": false,
  "vscord.status.problems.enabled": true,
  "vscord.status.problems.text": "- {problems_count} {problems_pluralize} found",
  "vscord.status.idle.check": true,
  "vscord.status.idle.enabled": true,
  "vscord.status.idle.disconnectOnIdle": false,
  "vscord.status.idle.timeout": 300,
  "vscord.status.details.enabled": true,
  "vscord.status.details.text.editing": "In {workspace} {problems}",
  "vscord.status.details.text.viewing": "In {workspace} {problems}",
  "vscord.status.state.enabled": true,
  "vscord.status.state.text.editing": "Working on {file_name}{file_extension}:{current_line}:{current_column}",
  "vscord.status.state.text.viewing": "Viewing {file_name}{file_extension}:{current_line}:{current_column}",
  "vscord.status.image.small.editing.text": "Visual Studio Code",
  "vscord.status.image.small.viewing.text": "Visual Studio Code",
  "vscord.status.buttons.button1.git.active.enabled": false,
  "vscord.status.buttons.button1.git.inactive.enabled": false,
  "vscord.status.buttons.button1.git.idle.enabled": false
}
